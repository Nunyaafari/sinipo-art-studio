# Runtime
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:3001

# Authentication
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Payments
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here
PAYMENT_MODE=test
PAYMENT_PROVIDER_NAME=Paystack

# Database
# Leave DATABASE_URL and DB_* blank if you are running without PostgreSQL locally.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_database_password_here
DB_NAME=sinipo_art

# Upload storage
UPLOAD_STORAGE=local
UPLOAD_LOCAL_PATH=uploads
MEDIA_BASE_URL=http://localhost:3001

# Cloudinary (required when UPLOAD_STORAGE=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Storefront shipping/tax/inventory defaults
STORE_CURRENCY=USD
FREE_SHIPPING_THRESHOLD=500
STANDARD_SHIPPING_COST=50
SHIPPING_LABEL=Standard delivery
ESTIMATED_DELIVERY=3-5 business days
TAX_ENABLED=false
TAX_RATE=0
TAX_LABEL=Sales tax
LOW_STOCK_THRESHOLD=3
GUEST_CHECKOUT_ENABLED=true
CHECKOUT_NOTICE=All payments are securely processed and confirmed before fulfillment begins.

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Monitoring and analytics
LOG_LEVEL=info
LOG_FILE_PATH=logs/backend.log
ALERT_WEBHOOK_URL=
SENTRY_DSN=
GOOGLE_ANALYTICS_ID=

# Backup and recovery
BACKUP_DIR=backups
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=

# Optional social providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
